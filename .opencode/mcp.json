{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\Projects\\DigitalSPB"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ]
    },
    "screenshot": {
      "command": "npx",
      "args": [
        "-y",
        "@just-every/mcp-screenshot-website-fast"
      ]
    },
    "penpot": {
      "command": "npx",
      "args": [
        "-y",
        "@penpot/mcp"
      ],
      "env": {
        "PENPOT_ACCESS_TOKEN": "your-penpot-token-here"
      }
    }
  }
}
